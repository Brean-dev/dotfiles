# -----------------------------------------------------
# ALIASES
# -----------------------------------------------------
alias upgreat='sudo apt update && sudo apt upgrade'
alias proj='cd $HOME/projects'
# -----------------------------------------------------
# General
# -----------------------------------------------------
alias c='clear'
alias nf='fastfetch'
alias pf='fastfetch'
alias ff='fastfetch'
alias ls='eza  --icons=always'
alias ll='eza -al --icons=always'
alias lt='eza -a --tree --level=1 --icons=always'
alias shutdown='systemctl poweroff'
alias v='$EDITOR'
alias vim='$EDITOR'
alias wifi='nmtui'

alias performance='sudo cpupower frequency-set -g performance'
alias powersave='sudo cpupower frequency-set -g powersave'
alias check_cpupower='watch -n 1 cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor'
# -----------------------------------------------------
alias update='echo "sudo dnf update -y && sudo dnf upgrade -y" && sudo dnf update -y && sudo dnf upgrade -y'

alias claude='claude --verbose'
